# BorrowHood Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env

# App
BH_APP_NAME=BorrowHood
BH_APP_URL=http://localhost:8000
BH_SECRET_KEY=change-me-to-random-64-chars
BH_DEBUG=true
BH_LOG_LEVEL=INFO

# Database
BH_DATABASE_URL=postgresql+asyncpg://borrowhood:borrowhood_pass@localhost:5432/borrowhood

# Keycloak (run: docker run -d -p 8080:8080 -e KEYCLOAK_ADMIN=admin -e KEYCLOAK_ADMIN_PASSWORD=admin quay.io/keycloak/keycloak:24.0.4 start-dev)
# Then import keycloak/borrowhood-realm-dev.json via admin console
BH_KC_URL=http://localhost:8080
BH_KC_REALM=borrowhood
BH_KC_CLIENT_ID=borrowhood-web
BH_KC_CLIENT_SECRET=

# Minio (S3-compatible storage)
BH_MINIO_URL=localhost:9000
BH_MINIO_ACCESS_KEY=change-me
BH_MINIO_SECRET_KEY=change-me
BH_MINIO_BUCKET=borrowhood

# Telegram Bot
BH_TELEGRAM_BOT_TOKEN=change-me
BH_TELEGRAM_ENABLED=false

# AI Provider: "auto" (cascade: gemini -> ollama -> pollinations -> template)
# Or force one: "gemini", "ollama", "pollinations"
BH_AI_PROVIDER=auto

# Google Gemini (get key at https://aistudio.google.com/apikey)
BH_GOOGLE_MAPS_API_KEY=change-me
BH_GOOGLE_API_KEY=change-me
BH_GEMINI_MODEL=gemini-2.5-flash

# Ollama (self-hosted LLM -- unlimited, no API limits, turbo speeds)
# Install: curl -fsSL https://ollama.com/install.sh | sh && ollama pull llama3.2
BH_OLLAMA_URL=
BH_OLLAMA_MODEL=llama3.2
